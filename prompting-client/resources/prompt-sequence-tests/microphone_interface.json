{
  "version": 1,
  "prompt-filter": {
    "snap": "prompting-client",
    "interface": "audio-record"
  },
  "prompts": [
    {
      "prompt-filter": { "interface": "audio-record" },
      "reply": {
        "action": "allow",
        "lifespan": "single",
        "constraints": { "permissions": [ "access" ] }
      }
    }
  ]
}
